---
// Pixel-perfect Footer matching stoneworld.co.in
---

<!-- Footer CTA Strip -->
<div style="background:#8B1A1A;text-align:center;padding:2.5rem 1rem;">
  <p style="font-family:'Jost',sans-serif;font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.85);margin:0 0 0.5rem;">CONTACT US TO MAKE CUSTOM DESIGNS FOR YOU</p>
  <p style="font-family:'Jost',sans-serif;color:rgba(255,255,255,0.7);font-size:0.9rem;margin:0 0 1.25rem;">Please get in touch and our expert support team will answer all your questions.</p>
  <a href="/contact-us/"
     style="display:inline-block;padding:0.7rem 2rem;background:#fff;color:#8B1A1A;font-family:'Jost',sans-serif;font-weight:700;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none;transition:background .2s,color .2s;"
     onmouseover="this.style.background='#1a1a1a';this.style.color='#fff'" onmouseout="this.style.background='#fff';this.style.color='#8B1A1A'">
    Get In Touch
  </a>
</div>

<!-- Main Footer -->
<footer style="background:#111;color:#ccc;padding:4rem 0 0;">
  <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:2.5rem;">
    
    <!-- Col 1: Brand -->
    <div>
      <a href="/">
        <img src="/images/Stone_World_white_logo.webp" alt="Stone World" style="height:55px;width:auto;margin-bottom:1.25rem;display:block;" />
      </a>
      <p style="font-size:0.875rem;line-height:1.7;color:#999;margin-bottom:1.25rem;">
        Crafting excellence with Indian natural stones. Innovation meets artistry for architects and designers worldwide.
      </p>
      <!-- Social -->
      <div style="display:flex;gap:0.75rem;align-items:center;">
        <a href="https://www.facebook.com/profile.php?id=100065373913876" target="_blank" rel="noopener"
           style="width:34px;height:34px;border:1px solid #444;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#999;transition:all .2s;text-decoration:none;"
           onmouseover="this.style.borderColor='#c9a96e';this.style.color='#c9a96e'" onmouseout="this.style.borderColor='#444';this.style.color='#999'">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/the.stone.world/?igshid=1jl1s5zkyiu15" target="_blank" rel="noopener"
           style="width:34px;height:34px;border:1px solid #444;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#999;transition:all .2s;text-decoration:none;"
           onmouseover="this.style.borderColor='#c9a96e';this.style.color='#c9a96e'" onmouseout="this.style.borderColor='#444';this.style.color='#999'">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="1.8"/><path stroke-width="1.8" d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2" stroke-linecap="round"/></svg>
        </a>
        <a href="https://pinterest.com/stoneworldindia/" target="_blank" rel="noopener"
           style="width:34px;height:34px;border:1px solid #444;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#999;transition:all .2s;text-decoration:none;"
           onmouseover="this.style.borderColor='#c9a96e';this.style.color='#c9a96e'" onmouseout="this.style.borderColor='#444';this.style.color='#999'">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        </a>
        <a href="https://www.youtube.com/channel/UCMos6wmfNwuL939Ed8ilnBQ" target="_blank" rel="noopener"
           style="width:34px;height:34px;border:1px solid #444;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#999;transition:all .2s;text-decoration:none;"
           onmouseover="this.style.borderColor='#c9a96e';this.style.color='#c9a96e'" onmouseout="this.style.borderColor='#444';this.style.color='#999'">
          <svg width="15" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
        </a>
      </div>
    </div>

    <!-- Col 2: Quick Links -->
    <div>
      <h4 style="font-family:'Libre Baskerville',serif;font-size:1rem;color:#fff;margin:0 0 1.25rem;letter-spacing:0.04em;">Quick Links</h4>
      <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.6rem;">
        {['About Us', 'Application Area', 'Our Collections', 'Blogs', 'Testimonials', 'Contact Us'].map(label => (
          <li>
            <a href={`/${label.toLowerCase().replace(/ /g, '-')}/`}
               style="color:#999;text-decoration:none;font-size:0.875rem;transition:color .2s;display:flex;align-items:center;gap:0.5rem;"
               onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#999'">
              <span style="color:#c9a96e;">›</span> {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Contact Info -->
    <div>
      <h4 style="font-family:'Libre Baskerville',serif;font-size:1rem;color:#fff;margin:0 0 1.25rem;letter-spacing:0.04em;">Get In Touch</h4>
      <div style="display:flex;flex-direction:column;gap:0.85rem;">
        <a href="tel:+916267967059" style="color:#999;text-decoration:none;font-size:0.875rem;display:flex;align-items:flex-start;gap:0.6rem;transition:color .2s;"
           onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#999'">
          <svg width="16" height="16" style="flex-shrink:0;margin-top:2px;" fill="none" stroke="#c9a96e" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          +91 6267967059
        </a>
        <a href="mailto:stoneworld.ind@gmail.com" style="color:#999;text-decoration:none;font-size:0.875rem;display:flex;align-items:flex-start;gap:0.6rem;transition:color .2s;"
           onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#999'">
          <svg width="16" height="16" style="flex-shrink:0;margin-top:2px;" fill="none" stroke="#c9a96e" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          stoneworld.ind@gmail.com
        </a>
        <a href="https://www.google.com/maps/place/Stone+World/@22.7117609,75.9042713,17z" target="_blank" rel="noopener"
           style="color:#999;text-decoration:none;font-size:0.875rem;display:flex;align-items:flex-start;gap:0.6rem;transition:color .2s;"
           onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#999'">
          <svg width="16" height="16" style="flex-shrink:0;margin-top:2px;" fill="none" stroke="#c9a96e" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          108-FB, Scheme No 94, Near Arpit Hospital, Ring Road, Indore, M.P. – 452018
        </a>
        <a href="https://wa.link/af3e0f" target="_blank" rel="noopener"
           style="margin-top:0.5rem;display:inline-flex;align-items:center;gap:0.5rem;padding:0.6rem 1.25rem;background:#25d366;color:#fff;font-family:'Jost',sans-serif;font-weight:600;font-size:0.8rem;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:background .2s;"
           onmouseover="this.style.background='#1fbb5a'" onmouseout="this.style.background='#25d366'">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Enquire Now
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="max-width:1200px;margin:2.5rem auto 0;padding:1.25rem 1.5rem;border-top:1px solid #2a2a2a;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:0.75rem;">
    <p style="margin:0;font-size:0.8125rem;color:#666;">Copyright &copy; 2026 Stone World. All Rights Reserved.</p>
    <div style="display:flex;gap:1.25rem;">
      <a href="/privacy-policy/" style="color:#666;font-size:0.8125rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#666'">Privacy Policy</a>
      <a href="/terms-and-conditions/" style="color:#666;font-size:0.8125rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#666'">Terms &amp; Conditions</a>
    </div>
  </div>
</footer>

<!-- WhatsApp Floating Button -->
<a href="https://wa.link/af3e0f" target="_blank" rel="noopener" class="wa-float" aria-label="Chat on WhatsApp">
  <svg width="28" height="28" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
</a>
