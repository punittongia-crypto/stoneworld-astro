---
// Stone World v3 — Premium Header (Brand-Aligned)
const currentPath = Astro.url.pathname;
function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href.replace(/\/$/, '') + '/');
}

const navLinks = [
  { href: '/about-us/',        label: 'About Us' },
  { href: '/application-area/', label: 'Application Area' },
  { href: '/our-collections/',  label: 'Our Collections' },
  { href: '/blog/',             label: 'Blogs' },
  { href: '/testimonials/',     label: 'Testimonials' },
];
---

<header id="site-header" class="sw-header">

  <!-- ===== TOP INFO BAR ===== -->
  <div class="sw-topbar">
    <div class="container">
      <div class="sw-topbar__inner">
        <!-- Left: contact info -->
        <div class="sw-topbar__left">
          <a href="mailto:stoneworld.ind@gmail.com" class="sw-topbar__link" aria-label="Email us">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            stoneworld.ind@gmail.com
          </a>
          <a href="tel:+916267967059" class="sw-topbar__link" aria-label="Call us">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            +91 6267967059
          </a>
        </div>
        <!-- Right: social icons -->
        <div class="sw-topbar__right">
          <a href="https://www.facebook.com/profile.php?id=100065373913876" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="sw-topbar__social">
            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/the.stone.world/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="sw-topbar__social">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="1.8"/>
              <path stroke-width="1.8" d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </a>
          <a href="https://pinterest.com/stoneworldindia/" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="sw-topbar__social">
            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
          <a href="https://www.youtube.com/channel/UCMos6wmfNwuL939Ed8ilnBQ" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="sw-topbar__social">
            <svg width="14" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== MAIN NAVIGATION ===== -->
  <div class="sw-nav">
    <div class="container">
      <div class="sw-nav__inner">
        <!-- Logo: Icon Mark + Wordmark -->
        <a href="/" class="sw-nav__logo" aria-label="Stone World — Home">
          <img src="/images/cropped-logo-1-1.png" alt="" width="38" height="38" class="sw-nav__logo-mark" />
          <span class="sw-nav__wordmark">
            <span class="sw-nav__wordmark-top">STONE WORLD</span>
            <span class="sw-nav__wordmark-sub">Natural Stone & Crafts</span>
          </span>
        </a>

        <!-- Desktop Nav Links -->
        <nav class="sw-nav__links" id="desktop-nav" aria-label="Main navigation">
          {navLinks.map(item => (
            <a href={item.href}
               class={`sw-nav__link ${isActive(item.href) ? 'sw-nav__link--active' : ''}`}
               aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>

        <!-- CTA Button -->
        <a href="/contact-us/" class="sw-nav__cta">
          Contact Us
        </a>

        <!-- Hamburger (mobile) -->
        <button id="hamburger" class="sw-nav__hamburger" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="sw-nav__ham-bar"></span>
          <span class="sw-nav__ham-bar"></span>
          <span class="sw-nav__ham-bar"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" role="navigation" aria-label="Mobile navigation">
      {navLinks.map(item => (
        <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
      ))}
      <a href="/contact-us/" class="mobile-cta">Contact Us</a>
    </div>
  </div>
</header>

<style>
/* --- Top Bar --- */
.sw-header {
  position: sticky;
  top: 0;
  z-index: 1000;
  transition: transform 0.3s ease;
}

.sw-topbar {
  background: #8B1A1A;
  color: rgba(255,255,255,0.85);
  font-size: 0.78rem;
  font-family: 'Jost', sans-serif;
  padding: 0.45rem 0;
}
.sw-topbar__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
}
.sw-topbar__left {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.sw-topbar__right {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.sw-topbar__link {
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  transition: color 0.2s;
  letter-spacing: 0.02em;
}
.sw-topbar__link:hover { color: #fff; }
.sw-topbar__social {
  color: rgba(255,255,255,0.6);
  transition: color 0.2s;
  display: flex;
  align-items: center;
}
.sw-topbar__social:hover { color: #fff; }

/* --- Main Nav --- */
.sw-nav {
  background: #fff;
  border-bottom: 1px solid #eee;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.sw-nav__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72px;
  gap: 1.5rem;
}

/* Logo Assembly */
.sw-nav__logo {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  flex-shrink: 0;
  text-decoration: none;
}
.sw-nav__logo-mark {
  width: 38px;
  height: 38px;
  object-fit: contain;
}
.sw-nav__wordmark {
  display: flex;
  flex-direction: column;
  line-height: 1;
}
.sw-nav__wordmark-top {
  font-family: 'Jost', sans-serif;
  font-size: 1.15rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: #1a1a1a;
  text-transform: uppercase;
}
.sw-nav__wordmark-sub {
  font-family: 'Jost', sans-serif;
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  color: #8B1A1A;
  text-transform: uppercase;
  margin-top: 2px;
}

/* Nav Links */
.sw-nav__links {
  display: flex;
  align-items: center;
  gap: 0;
  flex: 1;
  justify-content: center;
}
.sw-nav__link {
  display: inline-block;
  padding: 0.5rem 0.85rem;
  font-family: 'Jost', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #2d2d2d;
  text-decoration: none;
  transition: color 0.2s;
  white-space: nowrap;
  position: relative;
}
.sw-nav__link::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0.85rem;
  right: 0.85rem;
  height: 2px;
  background: #8B1A1A;
  transform: scaleX(0);
  transition: transform 0.3s;
}
.sw-nav__link:hover { color: #8B1A1A; }
.sw-nav__link:hover::after { transform: scaleX(1); }
.sw-nav__link--active { color: #8B1A1A; font-weight: 600; }
.sw-nav__link--active::after { transform: scaleX(1); }

/* CTA Button */
.sw-nav__cta {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: 'Jost', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.6rem 1.5rem;
  background: #8B1A1A;
  color: #fff;
  border: 2px solid #8B1A1A;
  text-decoration: none;
  transition: background 0.28s, color 0.28s;
  cursor: pointer;
}
.sw-nav__cta:hover {
  background: transparent;
  color: #8B1A1A;
}

/* Hamburger */
.sw-nav__hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
}
.sw-nav__ham-bar {
  display: block;
  width: 24px;
  height: 2px;
  background: #1a1a1a;
  transition: transform 0.3s, opacity 0.3s;
}

/* Mobile menu */
.mobile-cta {
  color: #8B1A1A !important;
  font-weight: 700 !important;
}

@media (max-width: 960px) {
  .sw-nav__links { display: none !important; }
  .sw-nav__cta   { display: none !important; }
  .sw-nav__hamburger { display: flex; }
}
@media (max-width: 600px) {
  .sw-topbar__left { gap: 0.8rem; font-size: 0.72rem; }
  .sw-nav__wordmark-top { font-size: 1rem; letter-spacing: 0.18em; }
}
</style>

<script>
  const btn = document.getElementById('hamburger') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  // Scroll-shrink effect
  const header = document.getElementById('site-header') as HTMLElement | null;
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const current = window.scrollY;
    if (header) {
      header.style.transform = (current > 80 && current > lastScroll) ? 'translateY(-36px)' : 'translateY(0)';
    }
    lastScroll = current;
  }, { passive: true });
</script>
