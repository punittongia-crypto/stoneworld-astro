---
import Layout from '../layouts/Layout.astro';

const showroomImages = [
  "https://stoneworld.co.in/wp-content/uploads/2025/03/showroom-1.jpg",
  "https://stoneworld.co.in/wp-content/uploads/2025/03/b51195da95e83a099cc7043bb8110c6f-1.jpg",
  "https://stoneworld.co.in/wp-content/uploads/2025/03/83a8a5d58d3e48eb73d496d438276eca-1.jpg",
  "https://stoneworld.co.in/wp-content/uploads/2025/03/c249b31ecbd9ccd8ed7e347f3b0ddc4c-1.jpg",
  "https://stoneworld.co.in/wp-content/uploads/2025/03/bd10f5cc69fb802f6bbb49060d35c9ae-1.jpg",
  "https://stoneworld.co.in/wp-content/uploads/2026/01/5e04250e0d3708b6f04b0dcd881740c9.webp",
];

const pillars = [
  {
    icon: `<svg width="36" height="36" fill="none" stroke="#8B1A1A" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
    title: "Production & Delivery",
    body: "With our in-house machines, we create a wide range of customized product designs and finishes. We provide 3D designs and concept drawings per customer requirement, starting production only after full approval. With showrooms in Indore and Delhi, we offer nation-wide delivery across India.",
  },
  {
    icon: `<svg width="36" height="36" fill="none" stroke="#8B1A1A" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/></svg>`,
    title: "Showroom & Live Concept Displays",
    body: "In May 2019, we opened Central India's largest natural stone showroom — 12,000 sq.ft. in Indore. We won the Best Stone Showroom Award in June 2020 by My FM Radio. Every wall and floor tells its own story, with every concept displayed live. No other showroom in India has implemented this concept.",
  },
  {
    icon: `<svg width="36" height="36" fill="none" stroke="#8B1A1A" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>`,
    title: "Values & Customer Relationships",
    body: "Stone World stands on core values of honesty, authenticity, integrity and culture, while striving to provide uniqueness, innovation, and customization. We focus on long-term relationships with our customers as well as with our super-skilled artisans and craftsmen.",
  },
];

const stats = [
  { number: "1000+", label: "Stone Products" },
  { number: "15+", label: "Years of Excellence" },
  { number: "12,000", label: "Sq. Ft. Showroom" },
  { number: "PAN India", label: "Delivery" },
];
---

<Layout
  title="About Us | Stone World - Premium Natural Stone Supplier"
  description="Learn about Stone World — founded in 2008, Central India's largest natural stone showroom. 1000+ products, nation-wide delivery, award-winning craftsmanship.">

  <!-- HERO -->
  <section class="cat-hero">
    <div class="cat-hero__overlay"></div>
    <img src={showroomImages[0]} alt="Stone World Showroom – Indore" loading="eager" />
    <div class="cat-hero__content">
      <span class="cat-hero__eyebrow">Our Story Since 2008</span>
      <h1>About Stone World</h1>
      <div class="cat-hero__rule"></div>
      <p class="cat-hero__sub">India's leading natural stone & crafts supplier</p>
    </div>
  </section>

  <!-- BREADCRUMB -->
  <nav class="cat-breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span>About Us</span>
    </div>
  </nav>

  <!-- BRAND STORY: 2-col editorial -->
  <section class="about-story">
    <div class="about-story__img">
      <img src={showroomImages[0]} alt="Stone World Showroom Interior" loading="lazy" />
      <div class="about-story__award">
        <svg width="22" height="22" fill="#c9a96e" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <div>
          <strong>Best Stone Showroom Award</strong>
          <span>My FM Radio, June 2020</span>
        </div>
      </div>
    </div>
    <div class="about-story__text">
      <span class="eyebrow">Who We Are</span>
      <h2 class="section-title" style="text-align:left;font-size:clamp(1.5rem,2.5vw,2.2rem);">A Leading Supplier of Quality Indian Natural Stone Products & Stone Crafts</h2>
      <span class="gold-rule" style="margin:1.25rem 0 1.75rem;display:block;width:50px;height:3px;background:#c9a96e;"></span>
      <p>Founded in 2008, Stone World has reached many milestones and attained new heights in a very short span of time. Our passion for Indian Natural Stones can be seen in our wide range of finishes and products.</p>
      <p>We are always experimenting and coming up with new innovative product ideas. We have a very different and unique thought process that brings architects, interior designers and customers from all over India to Stone World to find the perfect stone products.</p>
      <p>Every stone available in India is used in our innovative solutions — limestone, sandstone, marble, granite, quartzites, slate stones and more. Working with passion and innovation, we offer stone tiles, mosaics, wall cladding, garden pebbles, stone sculptures and crafts for interior and exterior projects.</p>
      <div class="about-story__ctas">
        <a href="https://wa.link/af3e0f" target="_blank" rel="noopener noreferrer" class="btn-primary">Send Your Requirements</a>
        <a href="/our-collections/" class="btn-outline">View Collections</a>
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <section class="about-stats">
    {stats.map(s => (
      <div class="about-stats__item">
        <span class="about-stats__number">{s.number}</span>
        <span class="about-stats__label">{s.label}</span>
      </div>
    ))}
  </section>

  <!-- THREE PILLARS -->
  <section class="about-pillars">
    <div class="container">
      <div class="text-center" style="margin-bottom:3.5rem;">
        <span class="eyebrow">What We Stand For</span>
        <h2 class="section-title">Our Core Commitments</h2>
        <span class="gold-rule gold-rule--center"></span>
      </div>
      <div class="pillars-grid">
        {pillars.map((p, i) => (
          <div class="pillar-card">
            <div class="pillar-card__icon" set:html={p.icon}></div>
            <h3 class="pillar-card__title">{p.title}</h3>
            <p class="pillar-card__body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SHOWROOM GALLERY STRIP -->
  <section class="about-gallery">
    <div class="container">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <span class="eyebrow">Visit Us</span>
        <h2 class="section-title">Central India's Largest Stone Showroom</h2>
        <span class="gold-rule gold-rule--center"></span>
        <p class="section-subtitle" style="margin-top:1rem;">12,000 sq.ft. of live concept displays — every wall and floor tells its own story</p>
      </div>
      <div class="gallery-strip">
        {showroomImages.slice(1).map((src, i) => (
          <div class="gallery-strip__item">
            <img src={src} alt={`Stone World Showroom — View ${i+2}`} loading="lazy" />
            <div class="gallery-strip__overlay"></div>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2rem;">
        <a href="/showroom/" class="btn-outline">Explore Full Showroom Gallery</a>
      </div>
    </div>
  </section>

  <!-- PRODUCTS SECTION -->
  <section class="about-products">
    <div class="about-products__inner container">
      <div class="about-products__text">
        <span class="eyebrow" style="color:#c9a96e;">Our Range</span>
        <h2 style="font-family:'Libre Baskerville',serif;font-size:clamp(1.4rem,2.5vw,2rem);color:#fff;margin:0.5rem 0 1.25rem;">1000+ Products. Every Stone Available in India.</h2>
        <p style="color:#bbb;line-height:1.85;">We work with every major natural stone — limestone, sandstone, marble, granite, quartzite, slate and more. From stone tiles and mosaics to CNC-carved sculptures, wall cladding to handcrafted stone crafts, Stone World is your one-stop supplier.</p>
        <ul class="product-list">
          <li>Stone Tiles & Mosaics</li>
          <li>Wall & Floor Cladding</li>
          <li>Stone Murals & Sculptures</li>
          <li>CNC-Carved Jaalies</li>
          <li>Stone Mandirs & Artefacts</li>
          <li>Garden Pebbles & Cobblestones</li>
          <li>Semi-Precious Gemstones</li>
          <li>Gold Leafing on Stone</li>
        </ul>
      </div>
      <div class="about-products__img">
        <img src="https://stoneworld.co.in/wp-content/uploads/2025/03/559eff297e26562e21343d08d272d2fa-1.jpg" alt="Stone World Products" loading="lazy" />
        <img src="https://stoneworld.co.in/wp-content/uploads/2025/03/a7e6e1ff77ead0d28545459e01c0fc3e-1.jpg" alt="Stone Crafts" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="cat-cta">
    <div class="container text-center">
      <span class="cat-cta__eyebrow">Experience It In Person</span>
      <h2 class="cat-cta__heading">Visit Our Showroom in Indore</h2>
      <p class="cat-cta__sub">108-FB, Scheme No 94, Near Arpit Hospital, Ring Road, Indore, M.P. – 452018</p>
      <div class="cat-cta__btns">
        <a href="/showroom/" class="btn-primary">View Showroom</a>
        <a href="/contact-us/" class="btn-gold-outline">Contact Us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ===== STORY SECTION ===== */
.about-story {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  max-width: 1300px;
  margin: 0 auto;
  padding: 5rem 1.5rem;
  align-items: center;
  gap: 4rem;
}
.about-story__img {
  position: relative;
  border-radius: 2px;
  overflow: hidden;
}
.about-story__img img {
  width: 100%;
  aspect-ratio: 4/3;
  object-fit: cover;
  display: block;
}
.about-story__award {
  position: absolute;
  bottom: 1.5rem;
  left: 1.5rem;
  background: #1a1a1a;
  padding: 0.85rem 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.85rem;
  border-left: 3px solid #c9a96e;
}
.about-story__award div {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}
.about-story__award strong {
  font-family: 'Jost', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.04em;
}
.about-story__award span {
  font-family: 'Jost', sans-serif;
  font-size: 0.7rem;
  color: #c9a96e;
}
.about-story__text p {
  font-family: 'Jost', sans-serif;
  color: #555;
  line-height: 1.85;
  margin-bottom: 1.15rem;
}
.about-story__ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 2rem;
}

/* ===== STATS STRIP ===== */
.about-stats {
  background: #1a1a1a;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 3.5rem 1.5rem;
}
.about-stats__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem;
  border-right: 1px solid rgba(255,255,255,0.08);
}
.about-stats__item:last-child { border-right: none; }
.about-stats__number {
  font-family: 'Libre Baskerville', serif;
  font-size: 2.5rem;
  font-weight: 700;
  color: #c9a96e;
  line-height: 1;
}
.about-stats__label {
  font-family: 'Jost', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #aaa;
}

/* ===== PILLARS ===== */
.about-pillars {
  padding: 5rem 0;
  background: #faf8f5;
}
.pillars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.pillar-card {
  background: #fff;
  padding: 2.5rem 2rem;
  border: 1px solid #f0ece5;
  border-top: 3px solid #8B1A1A;
  transition: box-shadow 0.35s, transform 0.35s;
}
.pillar-card:hover {
  box-shadow: 0 16px 40px rgba(139,26,26,0.1);
  transform: translateY(-4px);
}
.pillar-card__icon {
  margin-bottom: 1.25rem;
}
.pillar-card__title {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.15rem;
  font-weight: 700;
  color: #1a1a1a;
  margin: 0 0 0.85rem;
}
.pillar-card__body {
  font-family: 'Jost', sans-serif;
  font-size: 0.92rem;
  color: #666;
  line-height: 1.8;
  margin: 0;
}

/* ===== SHOWROOM GALLERY ===== */
.about-gallery {
  padding: 5rem 0;
  background: #fff;
}
.gallery-strip {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0.5rem;
}
.gallery-strip__item {
  position: relative;
  overflow: hidden;
  aspect-ratio: 2/3;
}
.gallery-strip__item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}
.gallery-strip__item:hover img { transform: scale(1.06); }
.gallery-strip__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(139,26,26,0.5) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.4s;
}
.gallery-strip__item:hover .gallery-strip__overlay { opacity: 1; }

/* ===== PRODUCTS SECTION ===== */
.about-products {
  background: #111;
  padding: 5rem 0;
}
.about-products__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.product-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem 1.5rem;
  margin: 1.5rem 0 0;
  padding: 0;
  list-style: none;
}
.product-list li {
  font-family: 'Jost', sans-serif;
  font-size: 0.88rem;
  color: #ccc;
  padding-left: 1rem;
  position: relative;
}
.product-list li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.55em;
  width: 5px;
  height: 5px;
  background: #c9a96e;
  border-radius: 50%;
}
.about-products__img {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.75rem;
}
.about-products__img img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  display: block;
}
.about-products__img img:first-child {
  margin-top: 2rem;
}

/* CTA reuse */
.cat-cta { background: #1a1a1a; padding: 5.5rem 1.5rem; }
.cat-cta__eyebrow { font-family: 'Jost', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: #c9a96e; display: block; margin-bottom: 0.75rem; }
.cat-cta__heading { font-family: 'Libre Baskerville', serif; font-size: clamp(1.6rem, 3vw, 2.5rem); color: #fff; margin: 0 0 1rem; font-weight: 700; }
.cat-cta__sub { font-family: 'Jost', sans-serif; color: #999; max-width: 520px; margin: 0 auto 2.25rem; line-height: 1.8; }
.cat-cta__btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

@media (max-width: 1024px) {
  .about-story { grid-template-columns: 1fr; gap: 2.5rem; }
  .about-stats { grid-template-columns: repeat(2, 1fr); }
  .about-stats__item:nth-child(2) { border-right: none; }
  .pillars-grid { grid-template-columns: 1fr; gap: 1.25rem; }
  .gallery-strip { grid-template-columns: repeat(3, 1fr); }
  .about-products__inner { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .about-stats { grid-template-columns: 1fr 1fr; }
  .gallery-strip { grid-template-columns: repeat(2, 1fr); }
  .gallery-strip__item:last-child { display: none; }
  .about-products__img { grid-template-columns: 1fr; }
  .about-products__img img:first-child { margin-top: 0; }
}
</style>
