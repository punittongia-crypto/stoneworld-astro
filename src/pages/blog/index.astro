---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) =>
  new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime()
);
---

<Layout
  title="Blog | Stone World - Natural Stone Design Ideas & Inspiration"
  description="Explore Stone World's blog for natural stone design ideas, home decor inspiration, and tips for using marble, granite, limestone in your spaces.">

  <!-- HERO BANNER -->
  <section class="cat-hero">
    <div class="cat-hero__overlay"></div>
    <img src="/wp-content/uploads/2025/03/inner-banner1.jpg" alt="Stone World Design Blog" loading="eager" />
    <div class="cat-hero__content">
      <span class="cat-hero__eyebrow">Design Inspiration</span>
      <h1>Our Blog</h1>
      <div class="cat-hero__rule"></div>
      <p class="cat-hero__sub">Insights, ideas and inspiration from our natural stone experts</p>
    </div>
  </section>

  <!-- BREADCRUMB -->
  <nav class="cat-breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span>Blog</span>
    </div>
  </nav>

  <!-- INTRO -->
  <section class="cat-intro">
    <div class="container text-center">
      <span class="eyebrow">Expert Articles</span>
      <h2 class="section-title">Stone Design Ideas & Inspiration</h2>
      <span class="gold-rule gold-rule--center"></span>
      <p class="section-subtitle">Discover the latest trends, design tips and expert insights on using natural stone in modern architecture and interior design.</p>
    </div>
  </section>

  <!-- BLOG GRID -->
  <section class="blog-grid-section">
    <div class="container">
      <div class="blog-grid">
        {sorted.map((post, i) => (
          <a href={`/blog/${post.data.slug}/`}
             class={`blog-card ${i === 0 ? 'blog-card--featured' : ''}`}
             id={`blog-${post.data.slug}`}>
            <div class="blog-card__img">
              {post.data.image ? (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  class="blog-card__img-actual"
                />
              ) : (
                <div class="blog-card__img-placeholder">
                  <svg width="40" height="40" fill="none" stroke="rgba(139,26,26,0.15)" viewBox="0 0 24 24" stroke-width="1">
                    <rect x="2" y="2" width="20" height="20" rx="3"/>
                    <circle cx="8.5" cy="8.5" r="2"/>
                    <path stroke-linecap="round" d="M2 14l6-4 4 3 3-2 7 5"/>
                  </svg>
                </div>
              )}
            </div>
            <div class="blog-card__body">
              {post.data.date && (
                <span class="blog-card__date">
                  {new Date(post.data.date).toLocaleDateString('en-IN', { year:'numeric', month:'long', day:'numeric' })}
                </span>
              )}
              <h3 class="blog-card__title">{post.data.title}</h3>
              {post.data.description && (
                <p class="blog-card__excerpt">{post.data.description.slice(0, 140)}…</p>
              )}
              <span class="blog-card__read">
                Read Article
                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA STRIP -->
  <section class="cat-cta">
    <div class="container text-center">
      <span class="cat-cta__eyebrow">Need Personalized Advice?</span>
      <h2 class="cat-cta__heading">Speak With Our Stone Experts</h2>
      <p class="cat-cta__sub">Our specialists are available for consultations on material selection, design guidance, and project planning.</p>
      <div class="cat-cta__btns">
        <a href="/contact-us/" class="btn-primary">Contact Us</a>
        <a href="/application-area/" class="btn-outline">Explore Applications</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* Hero — reuse from category pages */
.cat-hero { position: relative; height: 520px; overflow: hidden; }
.cat-hero img { width: 100%; height: 100%; object-fit: cover; }
.cat-hero__overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(139,26,26,0.75) 0%, rgba(26,26,26,0.65) 100%); z-index: 1; }
.cat-hero__content { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 2; text-align: center; padding: 0 1.5rem; }
.cat-hero__eyebrow { font-family: 'Jost', sans-serif; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase; color: #c9a96e; margin-bottom: 0.75rem; }
.cat-hero__content h1 { font-family: 'Libre Baskerville', serif; font-size: clamp(2.25rem, 5vw, 4rem); color: #fff; font-weight: 700; line-height: 1.15; margin: 0; }
.cat-hero__rule { width: 60px; height: 3px; background: #c9a96e; margin: 1.25rem auto; }
.cat-hero__sub { font-family: 'Jost', sans-serif; color: rgba(255,255,255,0.75); font-size: 1rem; max-width: 480px; margin: 0; }

.cat-breadcrumb { background: #fff; border-bottom: 1px solid #eee; padding: 0.75rem 0; }
.cat-breadcrumb .container { display: flex; align-items: center; gap: 0.5rem; font-family: 'Jost', sans-serif; font-size: 0.8rem; color: #999; }
.cat-breadcrumb a { color: #8B1A1A; text-decoration: none; }

.cat-intro { padding: 4.5rem 0 1rem; background: #fafaf8; }

/* ===== BLOG GRID ===== */
.blog-grid-section { padding: 3rem 0 6rem; background: #fafaf8; }
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

/* Blog Card */
.blog-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid #f0ece5;
  text-decoration: none;
  overflow: hidden;
  transition: transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94), box-shadow 0.45s;
}
.blog-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 50px rgba(139,26,26,0.1);
}

/* Featured first card */
.blog-card--featured {
  grid-column: span 2;
  grid-row: span 2;
  flex-direction: column;
}
.blog-card--featured .blog-card__img { min-height: 400px; }
.blog-card--featured .blog-card__title { font-size: 1.5rem; }

/* Blog Card Image */
.blog-card__img {
  overflow: hidden;
  min-height: 220px;
  position: relative;
}
.blog-card__img-actual {
  width: 100%;
  height: 100%;
  min-height: inherit;
  object-fit: cover;
  display: block;
  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.blog-card:hover .blog-card__img-actual { transform: scale(1.06); }
.blog-card__img-placeholder {
  width: 100%;
  height: 100%;
  min-height: inherit;
  background: linear-gradient(135deg, #f5f0e8, #ebe4d8);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s;
}
.blog-card:hover .blog-card__img-placeholder {
  background: linear-gradient(135deg, #ebe4d8, #ddd5c6);
}

/* Blog Card Body */
.blog-card__body {
  padding: 1.5rem 1.75rem 1.75rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.blog-card__date {
  font-family: 'Jost', sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #8B1A1A;
  margin-bottom: 0.6rem;
}
.blog-card__title {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  margin: 0 0 0.75rem;
  transition: color 0.3s;
}
.blog-card:hover .blog-card__title { color: #8B1A1A; }

.blog-card__excerpt {
  font-family: 'Jost', sans-serif;
  font-size: 0.88rem;
  color: #777;
  line-height: 1.75;
  margin: 0 0 1.25rem;
  flex: 1;
}
.blog-card__read {
  font-family: 'Jost', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #8B1A1A;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: auto;
  transition: gap 0.3s, color 0.3s;
}
.blog-card:hover .blog-card__read { gap: 0.7rem; color: #c9a96e; }

/* CTA */
.cat-cta { background: #1a1a1a; padding: 5.5rem 1.5rem; }
.cat-cta__eyebrow { font-family: 'Jost', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: #c9a96e; display: block; margin-bottom: 0.75rem; }
.cat-cta__heading { font-family: 'Libre Baskerville', serif; font-size: clamp(1.6rem, 3vw, 2.5rem); color: #fff; margin: 0 0 1rem; font-weight: 700; }
.cat-cta__sub { font-family: 'Jost', sans-serif; color: #999; max-width: 520px; margin: 0 auto 2.25rem; line-height: 1.8; }
.cat-cta__btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

@media (max-width: 1024px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
  .blog-card--featured { grid-column: span 2; grid-row: span 1; }
  .cat-hero { height: 420px; }
}
@media (max-width: 640px) {
  .blog-grid { grid-template-columns: 1fr; }
  .blog-card--featured { grid-column: span 1; }
  .blog-card--featured .blog-card__img { min-height: 200px; }
  .cat-hero { height: 340px; }
  .cat-cta { padding: 3.5rem 1.5rem; }
}
</style>
