---
import Layout from '../../layouts/Layout.astro';
import featuredImages from '../../data/featuredImages.json';

export async function getStaticPaths() {
  const data = await import('../../data/appPagesParsed.json').then(m => m.default);
  return Object.keys(data).map(slug => ({
    params: { slug },
    props: { page: data[slug], slug }
  }));
}

const { page, slug } = Astro.props;
const heroImage = featuredImages[slug]
  ? featuredImages[slug].replace('https://stoneworld.co.in', '')
  : '/wp-content/uploads/2025/03/inner-banner1.jpg';

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "ItemPage",
  "name": `${page.title} — Stone Applications | Stone World`,
  "url": `https://stoneworld.co.in/application-area/${slug}/`,
  "description": `Explore premium natural stone applications for ${page.title}. Stone World offers custom stone solutions, live project photos and 3D designs.`,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stoneworld.co.in/" },
      { "@type": "ListItem", "position": 2, "name": "Application Area", "item": "https://stoneworld.co.in/application-area/" },
      { "@type": "ListItem", "position": 3, "name": page.title, "item": `https://stoneworld.co.in/application-area/${slug}/` }
    ]
  }
};
---

<Layout
  title={`${page.title} - Natural Stone Applications | Stone World`}
  description={`Explore natural stone ${page.title.toLowerCase()} designs by Stone World. Premium Indian stone applications with live project photos, custom designs and professional consultation.`}
  image={`https://stoneworld.co.in${heroImage}`}
  schema={pageSchema}>

  <!-- HERO -->
  <div class="page-hero" style={`background-image:url('${heroImage}');`} role="banner">
    <div class="page-hero__inner">
      <span class="page-hero__eyebrow">Application Area</span>
      <h1>{page.title}</h1>
    </div>
  </div>

  <!-- BREADCRUMB -->
  <nav aria-label="Breadcrumb" style="background:#fff;border-bottom:1px solid #eee;padding:0.75rem 0;">
    <div class="container" style="display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;color:#888;font-family:'Jost',sans-serif;">
      <a href="/" style="color:#888;transition:color .2s;" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#888'">Home</a>
      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <a href="/application-area/" style="color:#888;transition:color .2s;" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#888'">Application Area</a>
      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span style="color:#c9a96e;font-weight:600;">{page.title}</span>
    </div>
  </nav>

  <!-- INTRO CONTENT -->
  <section class="section-pad" style="background:#fafaf8;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;">
        <!-- Left: Text -->
        <div class="sw-prose">
          <span class="eyebrow">Stone World Presents</span>
          {page.headings.length > 0 && <h2 class="section-title" style="margin-bottom:1rem;" set:html={page.headings[0]}></h2>}
          <span class="gold-rule"></span>
          {page.paragraphs.slice(0, 4).map((p: string) => (
            <p style="color:#4a4a4a;line-height:1.9;margin-bottom:1.25rem;" set:html={p}></p>
          ))}
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="/contact-us/" class="btn-primary">Request Consultation</a>
            <a href="/our-collections/" class="btn-outline">View Collections</a>
          </div>
        </div>
        <!-- Right: Hero image -->
        <div style="position:relative;">
          <img src={heroImage} alt={`${page.title} - Natural Stone Application by Stone World`}
               style="width:100%;height:440px;object-fit:cover;display:block;"
               loading="eager" />
          <div style="position:absolute;bottom:-1.5rem;right:-1.5rem;width:140px;height:140px;background:linear-gradient(135deg,#c9a96e,#e8c97a);z-index:-1;"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- REMAINING PARAGRAPHS (if any) -->
  {page.paragraphs.length > 4 && (
    <section style="padding:3rem 0;background:#fff;">
      <div class="container" style="max-width:860px;">
        {page.paragraphs.slice(4).map((p: string) => (
          <p style="color:#4a4a4a;line-height:1.9;margin-bottom:1.25rem;" set:html={p}></p>
        ))}
      </div>
    </section>
  )}

  <!-- KEY FEATURES -->
  {page.headings.length > 1 && (
    <section class="section-pad" style="background:#fff;">
      <div class="container">
        <div class="text-center" style="margin-bottom:3rem;">
          <span class="eyebrow">Why Choose Stone World</span>
          <h2 class="section-title">Key Benefits & Features</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem;">
          {page.headings.slice(1).map((heading: string) => (
            <div class="feature-box">
              <div class="feature-icon">
                <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3 set:html={heading}></h3>
              <span class="gold-rule"></span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- PROJECT GALLERY -->
  {page.images.length > 0 && (
    <section class="section-pad" style="background:#fafaf8;">
      <div class="container">
        <div class="text-center" style="margin-bottom:3rem;">
          <span class="eyebrow">Live Projects</span>
          <h2 class="section-title">Inspirations & Project Gallery</h2>
          <p class="section-subtitle">Real projects delivered by Stone World. Every image tells a story of craftsmanship.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem;">
          {page.images.map((img: string, i: number) => (
            <div class="gallery-card" style={i === 0 || i === 5 ? 'grid-column:span 2;aspect-ratio:16/9;' : ''}>
              <img src={img} alt={`${page.title} project by Stone World`} loading="lazy"
                   style="width:100%;height:100%;object-fit:cover;" />
              <div class="gallery-card__overlay">
                <p class="gallery-card__name">{page.title}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA STRIP -->
  <section style="background:#1a1a1a;padding:4rem 1.5rem;text-align:center;">
    <div class="container">
      <span class="eyebrow">Ready to Start?</span>
      <h2 style="font-family:'Libre Baskerville',serif;font-size:clamp(1.6rem,3vw,2.25rem);color:#fff;margin:0.5rem 0 1rem;">Get Expert Stone Consultation Today</h2>
      <p style="color:#aaa;max-width:500px;margin:0 auto 2rem;line-height:1.8;">Our team of stone experts will help you choose the perfect stone for your {page.title.toLowerCase()} project.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact-us/" class="btn-primary">Contact Us</a>
        <a href="https://wa.link/af3e0f" target="_blank" rel="noopener noreferrer" class="btn-gold-outline">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
@media (max-width: 900px) {
  section[style*="grid-template-columns:1fr 1fr"] > div,
  section[style*="grid-template-columns:1fr 1fr"] .container > div {
    grid-template-columns: 1fr !important;
    gap: 2.5rem !important;
  }
  .gallery-card[style*="grid-column:span 2"] { grid-column: span 1 !important; aspect-ratio: 4/3 !important; }
}
@media (max-width: 600px) {
  div[style*="grid-template-columns:repeat(auto-fill,minmax(320px"] { grid-template-columns: 1fr 1fr !important; }
}
</style>
