---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const data = await import('../../data/collectionPagesParsed.json').then(m => m.default);
  return Object.keys(data).map(slug => ({
    params: { slug },
    props: { page: data[slug], slug }
  }));
}

const { page, slug } = Astro.props;
const heroImage = page.images.length > 0 ? page.images[0] : '/wp-content/uploads/2025/03/inner-banner1.jpg';

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${page.title} — Collections | Stone World`,
  "url": `https://stoneworld.co.in/our-collections/${slug}/`,
  "description": `Explore our premium ${page.title} collection at Stone World. Hand-selected natural stones for architects and interior designers.`,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stoneworld.co.in/" },
      { "@type": "ListItem", "position": 2, "name": "Our Collections", "item": "https://stoneworld.co.in/our-collections/" },
      { "@type": "ListItem", "position": 3, "name": page.title, "item": `https://stoneworld.co.in/our-collections/${slug}/` }
    ]
  }
};
---

<Layout
  title={`${page.title} — Exclusive Stone Collections | Stone World`}
  description={`Discover our premium ${page.title} collection. Hand-selected Indian natural stones for architects, interior designers and discerning homeowners.`}
  image={`https://stoneworld.co.in${heroImage}`}
  schema={pageSchema}>

  <!-- HERO -->
  <div class="page-hero" style={`background-image:url('${heroImage}');`} role="banner">
    <div class="page-hero__inner">
      <span class="page-hero__eyebrow">Our Collections</span>
      <h1>{page.title}</h1>
    </div>
  </div>

  <!-- BREADCRUMB -->
  <nav aria-label="Breadcrumb" style="background:#fff;border-bottom:1px solid #eee;padding:0.75rem 0;">
    <div class="container" style="display:flex;align-items:center;gap:0.5rem;font-size:0.8rem;color:#888;font-family:'Jost',sans-serif;">
      <a href="/" style="color:#888;transition:color .2s;" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#888'">Home</a>
      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <a href="/our-collections/" style="color:#888;transition:color .2s;" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='#888'">Our Collections</a>
      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span style="color:#c9a96e;font-weight:600;">{page.title}</span>
    </div>
  </nav>

  <!-- INTRO -->
  <section class="section-pad" style="background:#fafaf8;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;">
        <div class="sw-prose">
          <span class="eyebrow">Stone World Collection</span>
          {page.headings.length > 0 && <h2 class="section-title" style="margin-bottom:1rem;" set:html={page.headings[0]}></h2>}
          <span class="gold-rule"></span>
          {page.paragraphs.slice(0, 4).map((p: string) => (
            <p style="color:#4a4a4a;line-height:1.9;margin-bottom:1.25rem;" set:html={p}></p>
          ))}
          <div style="margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="/contact-us/" class="btn-primary">Request a Sample</a>
            <a href="/application-area/" class="btn-outline">Explore Applications</a>
          </div>
        </div>
        <div style="position:relative;">
          <img src={heroImage} alt={`${page.title} — Stone World Collection`}
               style="width:100%;height:440px;object-fit:cover;display:block;" loading="eager" />
          <div style="position:absolute;bottom:-1.5rem;right:-1.5rem;width:140px;height:140px;background:linear-gradient(135deg,#c9a96e,#e8c97a);z-index:-1;"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  {page.headings.length > 1 && (
    <section class="section-pad" style="background:#fff;">
      <div class="container">
        <div class="text-center" style="margin-bottom:3rem;">
          <span class="eyebrow">Collection Highlights</span>
          <h2 class="section-title">What Makes This Collection Special</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem;">
          {page.headings.slice(1).map((heading: string) => (
            <div class="feature-box">
              <div class="feature-icon">
                <svg width="22" height="22" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3 set:html={heading}></h3>
              <span class="gold-rule"></span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- GALLERY -->
  {page.images.length > 0 && (
    <section class="section-pad" style="background:#fafaf8;">
      <div class="container">
        <div class="text-center" style="margin-bottom:3rem;">
          <span class="eyebrow">Collection Gallery</span>
          <h2 class="section-title">Browse Our {page.title}</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.25rem;">
          {page.images.map((img: string, i: number) => (
            <div class="gallery-card">
              <img src={img} alt={`${page.title} — Stone World`} loading="lazy"
                   style="width:100%;height:100%;object-fit:cover;" />
              <div class="gallery-card__overlay">
                <p class="gallery-card__name">{page.title}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section style="background:#1a1a1a;padding:4rem 1.5rem;text-align:center;">
    <div class="container">
      <span class="eyebrow">Interested?</span>
      <h2 style="font-family:'Libre Baskerville',serif;font-size:clamp(1.6rem,3vw,2.25rem);color:#fff;margin:0.5rem 0 1rem;">Request Samples or a Custom Quote</h2>
      <p style="color:#aaa;max-width:500px;margin:0 auto 2rem;line-height:1.8;">Get in touch with our experts for material consultation, samples and competitive pricing.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/contact-us/" class="btn-primary">Contact Us</a>
        <a href="https://wa.link/af3e0f" target="_blank" rel="noopener noreferrer" class="btn-gold-outline">WhatsApp Us</a>
      </div>
    </div>
  </section>

</Layout>

<style>
@media (max-width: 900px) {
  .container > div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
}
</style>
