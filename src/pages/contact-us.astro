---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us | Stone World - Get Expert Stone Solutions Today"
  description="Have a query or need expert guidance? Contact Stone World today for personalized support on natural stone designs and solutions.">

  <!-- HERO BANNER -->
  <section class="cat-hero">
    <div class="cat-hero__overlay"></div>
    <img src="/wp-content/uploads/2025/03/inner-banner1.jpg" alt="Contact Stone World" loading="eager" />
    <div class="cat-hero__content">
      <span class="cat-hero__eyebrow">Reach Out</span>
      <h1>Contact Us</h1>
      <div class="cat-hero__rule"></div>
      <p class="cat-hero__sub">Let's create something beautiful together with natural stone</p>
    </div>
  </section>

  <!-- BREADCRUMB -->
  <nav class="cat-breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span>Contact Us</span>
    </div>
  </nav>

  <!-- Contact Section -->
  <section style="padding:5rem 0;background:#fff;">
    <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;">

      <!-- Contact Info -->
      <div>
        <p style="font-family:'Jost',sans-serif;font-size:0.8rem;letter-spacing:0.2em;text-transform:uppercase;color:#c9a96e;margin:0 0 0.5rem;">Get In Touch</p>
        <h2 style="font-family:'Libre Baskerville',serif;font-size:clamp(1.5rem,2.5vw,2rem);color:#1a1a1a;margin:0 0 1.5rem;">Let's Create Something Beautiful Together</h2>
        <p style="color:#666;line-height:1.8;margin-bottom:2.5rem;">Our expert team is ready to help you find the perfect natural stone solution for your project. Reach out through any of the channels below.</p>

        <!-- Contact Cards -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <a href="tel:+916267967059" style="display:flex;align-items:center;gap:1.25rem;padding:1.25rem;background:#fafaf8;text-decoration:none;border-left:3px solid #c9a96e;transition:box-shadow .2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='none'">
            <div style="width:44px;height:44px;background:#c9a96e;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="18" height="18" fill="none" stroke="#fff" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:#999;margin:0 0 0.2rem;">Phone</p>
              <p style="font-size:1rem;font-weight:600;color:#1a1a1a;margin:0;">+91 6267967059</p>
            </div>
          </a>

          <a href="mailto:stoneworld.ind@gmail.com" style="display:flex;align-items:center;gap:1.25rem;padding:1.25rem;background:#fafaf8;text-decoration:none;border-left:3px solid #c9a96e;transition:box-shadow .2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='none'">
            <div style="width:44px;height:44px;background:#c9a96e;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="18" height="18" fill="none" stroke="#fff" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:#999;margin:0 0 0.2rem;">Email</p>
              <p style="font-size:1rem;font-weight:600;color:#1a1a1a;margin:0;">stoneworld.ind@gmail.com</p>
            </div>
          </a>

          <a href="https://www.google.com/maps/place/Stone+World/@22.7117609,75.9042713,17z" target="_blank" rel="noopener" style="display:flex;align-items:flex-start;gap:1.25rem;padding:1.25rem;background:#fafaf8;text-decoration:none;border-left:3px solid #c9a96e;transition:box-shadow .2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='none'">
            <div style="width:44px;height:44px;background:#c9a96e;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
              <svg width="18" height="18" fill="none" stroke="#fff" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <p style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:#999;margin:0 0 0.2rem;">Address</p>
              <p style="font-size:0.95rem;font-weight:600;color:#1a1a1a;margin:0;line-height:1.5;">108-FB, Scheme No 94, Near Arpit Hospital,<br/>Ring Road, Near Pipliyahana Square,<br/>Indore, M. P. – 452018</p>
            </div>
          </a>

          <a href="https://wa.link/af3e0f" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:1.25rem;padding:1.25rem;background:#25d366;text-decoration:none;border-left:3px solid #1fbb5a;transition:opacity .2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
            <div style="width:44px;height:44px;background:rgba(255,255,255,0.25);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="22" height="22" fill="#fff" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </div>
            <div>
              <p style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.8);margin:0 0 0.2rem;">WhatsApp</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;">Enquire Now on WhatsApp</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Google Maps Embed -->
      <div>
        <p style="font-family:'Jost',sans-serif;font-size:0.8rem;letter-spacing:0.2em;text-transform:uppercase;color:#c9a96e;margin:0 0 0.5rem;">Find Us</p>
        <h2 style="font-family:'Libre Baskerville',serif;font-size:1.5rem;color:#1a1a1a;margin:0 0 1.25rem;">Our Showroom Location</h2>
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3681.134!2d75.9042713!3d22.7117609!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3962e2cdc3d73bef%3A0x71408d9487448470!2sStone%20World!5e0!3m2!1sen!2sin!4v1234567890"
          width="100%"
          height="420"
          style="border:0;display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Stone World Location Map">
        </iframe>
        <div style="padding:1rem;background:#fafaf8;border:1px solid #eee;">
          <p style="margin:0;font-size:0.875rem;color:#666;line-height:1.7;">
            <strong style="color:#1a1a1a;">Stone World</strong><br/>
            108-FB, Scheme No 94, Near Arpit Hospital, Ring Road, Near Pipliyahana Square, Indore, M. P. – 452018
          </p>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  @media(max-width:768px) {
    section > div[style*='grid-template-columns:1fr 1fr'] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
