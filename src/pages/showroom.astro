---

<Layout title={title} description={description}>

<!-- Hero Banner -->
<section class="cat-hero">
  <div class="cat-hero__overlay"></div>
  <img src={showroomImages[0].src} alt="Stone World Showroom – Indore" loading="eager" />
  <div class="cat-hero__content">
    <span class="cat-hero__eyebrow">Visit Us</span>
    <h1>Our Showroom</h1>
    <div class="cat-hero__rule"></div>
    <p class="cat-hero__sub">Experience the beauty of natural stone at Central India's largest stone showroom</p>
  </div>
</section>

<!-- Breadcrumb -->
<nav class="cat-breadcrumb" aria-label="Breadcrumb">
  <div class="container">
    <a href="/">Home</a>
    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span>Showroom</span>
  </div>
</nav>

<!-- Intro Section -->
<section style="max-width:900px;margin:0 auto;padding:2rem 1.5rem 3rem;text-align:center;">
  <p style="font-family:'Jost',sans-serif;font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;color:#8B1A1A;margin-bottom:0.5rem;">STONE WORLD SHOWROOM</p>
  <h2 style="font-family:'Libre Baskerville',serif;font-size:2rem;color:#1a1a1a;margin:0 0 1rem;">Where Craftsmanship Meets Inspiration</h2>
  <p style="font-family:'Jost',sans-serif;font-size:1rem;color:#555;line-height:1.8;max-width:700px;margin:0 auto;">
    Step into Stone World's showroom in Indore to explore our complete range of natural stone products, handcrafted artefacts, stone murals, CNC-carved designs, and bespoke installations. Each piece tells a story of artisanal excellence.
  </p>
</section>

<!-- Masonry Gallery -->
<section class="showroom-gallery">
  <div class="gallery-grid">
    {showroomImages.slice(1).map((img, i) => (
      <div class={`gallery-item ${img.tall ? 'gallery-item--tall' : ''} ${img.wide ? 'gallery-item--wide' : ''}`}>
        <img src={img.src} alt={img.alt} loading="lazy" />
        <div class="gallery-item__overlay">
          <span>{img.alt}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Location CTA -->
<section style="background:#f5f0eb;padding:4rem 1.5rem;margin-top:3rem;">
  <div style="max-width:900px;margin:0 auto;text-align:center;">
    <p style="font-family:'Jost',sans-serif;font-size:0.8rem;letter-spacing:0.15em;text-transform:uppercase;color:#8B1A1A;margin-bottom:0.5rem;">VISIT OUR SHOWROOM</p>
    <h2 style="font-family:'Libre Baskerville',serif;font-size:1.8rem;color:#1a1a1a;margin:0 0 1rem;">Plan Your Visit</h2>
    <p style="font-family:'Jost',sans-serif;color:#555;margin:0 0 0.5rem;">
      <strong>Address:</strong> 108-FB, Scheme No 94, Near Arpit Hospital, Ring Road, Near Pipliyahana Square, Indore, M.P. – 452018
    </p>
    <p style="font-family:'Jost',sans-serif;color:#555;margin:0 0 0.5rem;">
      <strong>Phone:</strong> <a href="tel:+916267967059" style="color:#8B1A1A;">+91 6267967059</a>
    </p>
    <p style="font-family:'Jost',sans-serif;color:#555;margin:0 0 1.5rem;">
      <strong>Email:</strong> <a href="mailto:stoneworld.ind@gmail.com" style="color:#8B1A1A;">stoneworld.ind@gmail.com</a>
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="https://www.google.com/maps/place/Stone+World/@22.7117609,75.9042713,17z" target="_blank" rel="noopener" class="btn-primary" style="display:inline-block;padding:0.75rem 2rem;background:#8B1A1A !important;color:#fff !important;font-family:'Jost',sans-serif;font-weight:600;font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;transition:all .3s;">
        Get Directions
      </a>
      <a href="/contact-us/" class="btn-outline" style="display:inline-block;padding:0.75rem 2rem;border:2px solid #8B1A1A !important;color:#8B1A1A !important;font-family:'Jost',sans-serif;font-weight:600;font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;background:transparent !important;transition:all .3s;">
        Book Consultation
      </a>
    </div>
  </div>
</section>

</Layout>

<style>
/* Legacy showroom hero styles removed - now uses global .cat-hero */

/* Gallery Grid */
.showroom-gallery {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
}
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
}
.gallery-item {
  position: relative;
  overflow: hidden;
  border-radius: 4px;
  cursor: pointer;
}
.gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  aspect-ratio: 3/2;
  transition: transform 0.5s ease;
}
.gallery-item--tall img {
  aspect-ratio: 2/3;
}
.gallery-item--tall {
  grid-row: span 2;
}
.gallery-item--wide {
  grid-column: span 2;
}
.gallery-item__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(139,26,26,0.8) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.4s ease;
  display: flex;
  align-items: flex-end;
  padding: 1rem;
}
.gallery-item__overlay span {
  font-family: 'Jost', sans-serif;
  color: #fff;
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.05em;
}
.gallery-item:hover .gallery-item__overlay {
  opacity: 1;
}
.gallery-item:hover img {
  transform: scale(1.05);
}

@media (max-width: 768px) {
  .gallery-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .gallery-grid {
    grid-template-columns: 1fr;
  }
}
</style>
